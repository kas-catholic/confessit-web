---
import { m } from "../paraglide/messages.js";
import { getLocale, localizeHref, locales } from "../paraglide/runtime.js";
import localeEmoji from "locale-emoji";
import ISO6391 from "iso-639-1";
import { TrashIcon, PlusIcon } from "@heroicons/react/16/solid";

import "@styles/base.css";
interface Props {
  title: string;
  bodyClass?: string;
}

const { title, bodyClass = "" } = Astro.props;
const currentLocale = getLocale();
const cannonicalUrl = new URL(Astro.url.pathname, Astro.site);

function localizedPath(path: string, locale?: string): string {
  const result = locale ? localizeHref(path, { locale }) : localizeHref(path);
  if (result === "/") return "/";
  return result.endsWith("/") ? result : result + "/";
}
---

<!doctype html>
<html lang={currentLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content={m["about.about_confessit_text"]().replace(/<[^>]+>/g, "")}
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="192x192" href="/logo192.png" />
    <link rel="apple-touch-icon" sizes="512x512" href="/logo512.png" />
    <meta name="msapplication-TileColor" content="#dcbda9" />
    <meta name="theme-color" content="#dcbda9" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <link rel="canonical" href={cannonicalUrl} />
    {
      locales.map((lng) => (
        <link
          rel="alternate"
          hreflang={lng}
          href={new URL(localizedPath(Astro.url.pathname, lng), Astro.site).href}
        />
      ))
    }

    <link rel="manifest" href="/manifest.json" />

    <meta name="og:title" content={title} />
    <meta name="og:image" content="/social_image.png" />
    <meta name="og:url" content={cannonicalUrl} />
    <meta name="og:type" content="website" />
  </head>
  <body class={bodyClass}>
    <div class="navbar h-16 bg-base-300 text-base-content">
      <div class="navbar-start">
        <!-- On small screens, show a dropdown menu -->
        <details class="dropdown">
          <summary class="btn btn-ghost lg:hidden">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h8m-8 6h16"></path>
            </svg>
          </summary>
          <ul
            class="menu menu-lg dropdown-content bg-base-200 rounded-box z-100 mt-3 w-56 p-4 shadow"
          >
            <li>
              <a href={localizedPath("/prayers/")}>{m["navbar.prayers"]()}</a>
            </li>
            <li>
              <details>
                <summary>{m["navbar.about"]()}</summary>
                <ul class="p-2">
                  <li><a href={localizedPath("/about/")}>ConfessIt</a></li>
                  <li>
                    <a href={localizedPath("/about-confession/")}
                      >{m["navbar.confession"]()}</a
                    >
                  </li>
                  <li>
                    <a href={localizedPath("/about-confessit-android/")}
                      >{m["navbar.confessit_android"]()}</a
                    >
                  </li>
                </ul>
              </details>
            </li>
            <li>
              <a href={localizedPath("/help/")}>{m["navbar.help"]()}</a>
            </li>
            <li>
              <select
                onchange="location = this.value;"
                class="select select-sm text-xs select-bordered mt-8 py-1 w-42 font-noto"
              >
                {
                  locales.map((lng) => {
                    const flag = localeEmoji(lng) ? localeEmoji(lng) + " " : "";
                    const nativeName =
                      lng === "pt-BR"
                        ? "Português"
                        : ISO6391.getNativeName(lng) || lng;
                    return (
                      <option
                        value={localizedPath(Astro.url.pathname, lng)}
                        selected={lng === currentLocale}
                      >
                        {flag + nativeName}
                      </option>
                    );
                  })
                }
              </select>
            </li>
          </ul>
        </details>

        {/* Use h1 only on the homepage (SEO) */}
        {
          Astro.url.pathname === localizedPath("/") && (
            <h1>
              <a class="btn btn-ghost text-2xl" href={localizedPath("/")}>
                ⛪ ConfessIt
              </a>
            </h1>
          )
        }
        {
          Astro.url.pathname !== localizedPath("/") && (
            <a class="btn btn-ghost text-2xl" href={localizedPath("/")}>
              ⛪ ConfessIt
            </a>
          )
        }

        <!-- On large screens, show a menu -->
        <div class="hidden lg:flex z-50">
          <ul class="menu menu-horizontal px-1 gap-1 text-lg">
            <li>
              <a href={localizedPath("/prayers/")}>{m["navbar.prayers"]()}</a>
            </li>
            <li>
              <details>
                <summary>{m["navbar.about"]()}</summary>
                <ul class="bg-base-200 rounded-t-none p-2 w-60">
                  <li><a href={localizedPath("/about/")}>ConfessIt</a></li>
                  <li>
                    <a href={localizedPath("/about-confession/")}
                      >{m["navbar.confession"]()}</a
                    >
                  </li>
                  <li>
                    <a href={localizedPath("/about-confessit-android/")}
                      >{m["navbar.confessit_android"]()}</a
                    >
                  </li>
                </ul>
              </details>
            </li>
            <li><a href={localizedPath("/help/")}>{m["navbar.help"]()}</a></li>
          </ul>
        </div>
      </div>

      <div class="navbar-end">
        <!-- On large screens, show a menu -->
        <div class="flex gap-4">
          {
            Astro.url.pathname === localizedPath("/") && (
              <button
                id="add-sin-button"
                class="btn btn-secondary"
                title={m["addbutton.add-custom-sin"]()}
                onclick="AddSinModal.showModal()"
              >
                <PlusIcon className="h-5" />
              </button>
            )
          }
          <select
            onchange="location = this.value;"
            class="hidden lg:inline-flex select select-bordered w-36 font-noto"
          >
            {
              locales.map((lng) => {
                const flag = localeEmoji(lng) ? localeEmoji(lng) + " " : "";
                const nativeName =
                  lng === "pt-BR"
                    ? "Português"
                    : ISO6391.getNativeName(lng) || lng;
                return (
                  <option
                    value={localizedPath(Astro.url.pathname, lng)}
                    selected={lng === currentLocale}
                  >
                    {flag + nativeName}
                  </option>
                );
              })
            }
          </select>
        </div>
      </div>
    </div>
    <slot />
  </body>
</html>
