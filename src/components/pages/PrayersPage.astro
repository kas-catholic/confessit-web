  <h2 id="another-act-of-contrition">
    {m["prayers.another_act_of_contrition"]()}
  </h2>
  <p>
    <ParaglideTrans key="prayers.another_act_of_contrition_text" />
  </p>

  <h2 id="thanksgiving-after-confession">
    {m["prayers.thanksgiving_after_confession"]()}
  </h2>
  <p>
    <ParaglideTrans key="prayers.thanksgiving_after_confession_text" />
  </p>

  <h2 id="our-father">
    {m["prayers.our_father"]()}
  </h2>
  <p>
    <ParaglideTrans key="prayers.our_father_text" />
  </p>

  <h2 id="hail-mary">
    {m["prayers.hail_mary"]()}
  </h2>
  <p>
    <ParaglideTrans key="prayers.hail_mary_text" />
  </p>

  <h2 id="hail-holy-queen">
    {m["prayers.hail_holy_queen"]()}
  </h2>
  <p>
    <ParaglideTrans key="prayers.hail_holy_queen_text" />
  </p>
