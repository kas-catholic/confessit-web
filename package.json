{
  "name": "confessit-web",
  "type": "module",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "npx eslint src",
    "prepare": "husky"
  },
  "eslintConfig": {
    "extends": "react-app",
    "rules": {
      "jsx-a11y/anchor-has-content": "off"
    }
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@dnd-kit/helpers": "^0.5.0",
    "@dnd-kit/react": "^0.5.0",
    "@heroicons/react": "^2.2.0",
    "@inlang/paraglide-js": "^2.21.0",
    "@tailwindcss/vite": "4.0.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.9",
    "iso-639-1": "^3.1.6",
    "locale-emoji": "^0.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "swiper": "^14.0.5",
    "tailwindcss": "4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@tailwindcss/typography": "^0.5.16",
    "daisyui": "^5.6.18",
    "eslint": "^9.39.5",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "jest": {
    "transformIgnorePatterns": [
      "/node_modules/(?!(swiper|ssr-window|dom7)/)"
    ]
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "sharp@0.34.5": true,
    "esbuild@0.28.1": true
  }
}
